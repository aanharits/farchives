---
import "@fontsource-variable/montserrat";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Software Developer" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="preconnect" href="https://open.spotify.com" />
    <link rel="dns-prefetch" href="https://open.spotify.com" />
    <meta property="og:title" content="farchives" />
    <meta property="og:description" content="Software Developer" />
    <meta
      property="og:image"
      content="https://farhanharitsprakoso.vercel.app/og.image.png"
    />
    <meta property="og:url" content="https://farhanharitsprakoso.vercel.app" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="farchive" />

    <title>{title}</title>

    <!-- GSAP + ScrollTrigger -->
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/gsap.min.js"></script>
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/ScrollTrigger.min.js"
    ></script>
    <!-- Lenis -->
    <script is:inline src="https://unpkg.com/lenis@1.1.20/dist/lenis.min.js"
    ></script>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          orientation: "vertical",
          gestureOrientation: "vertical",
          smoothWheel: true,
          wheelMultiplier: 1,
          smoothTouch: false,
          touchMultiplier: 2,
          infinite: false,
        });

        if (window.gsap && window.ScrollTrigger) {
          lenis.on("scroll", ScrollTrigger.update);
          gsap.ticker.add((time) => {
            lenis.raf(time * 1000);
          });
          gsap.ticker.lagSmoothing(0, 0);
        } else {
          function raf(time) {
            lenis.raf(time);
            requestAnimationFrame(raf);
          }
          requestAnimationFrame(raf);
        }
      });
    </script>
  </head>
  <body class="bg-[--background]">
    <slot />
  </body>
</html>

<style is:global>
  /* Ensure fixed nav elements are always visible */
  #hamburger-btn,
  #theme-toggle {
    position: fixed !important;
    will-change: transform;
    transform: translateZ(0);
  }

  :root {
    --background: #131513;
    --sec: #648e46;
    --white: #dfdfdf;
    --white-icon: #f3f3f398;
    --white-icon-tr: #f3f3f310;
    --component-bg: #1a1d1a;
    --nav-active: #ffffff;
  }

  [data-theme="light"] {
    --background: #f0e9d4;
    --sec: #74824a;
    --white: #41431b;
    --white-icon: #41431b98;
    --white-icon-tr: #41431b10;
    --component-bg: #d7d0b6;
    --nav-active: #41431b;
  }

  html,
  body {
    transition:
      background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      color 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Smooth theme transition for all elements */
  *,
  *::before,
  *::after {
    transition:
      background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      border-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      fill 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      stroke 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Re-allow fast transitions for interactive/animated elements */
  button,
  a,
  [class*="transition"],
  [class*="duration"],
  [class*="ease"] {
    transition-duration: revert !important;
    transition-timing-function: revert !important;
  }

  /* Alternating section styling */
  .alt-section {
    background-color: var(--sec) !important;
  }

  /* Apply text color to direct text elements unless they are inside a card (.themed-card) */
  .alt-section h1:not(.themed-card *),
  .alt-section h2:not(.themed-card *),
  .alt-section h3:not(.themed-card *),
  .alt-section h4:not(.themed-card *) {
    color: var(--background) !important;
  }
  .alt-section p:not(.themed-card *),
  .alt-section span:not(.themed-card *),
  .alt-section a:not(.themed-card *) {
    color: var(--background) !important;
  }
  .alt-section border:not(.themed-card *) {
    border-color: color-mix(
      in srgb,
      var(--background) 20%,
      transparent
    ) !important;
  }
  /* Preserve some specific elements in alt-section */
  .alt-section .exp-badge:not(.themed-card *) {
    color: var(--background) !important;
  }
  .alt-section svg:not(.themed-card *) {
    stroke: var(--background) !important;
  }
  .alt-section [class*="text-[var(--sec)]"]:not(.themed-card *) {
    color: var(--background) !important;
  }

  @font-face {
    font-family: "Montserrat Variable";
    font-display: swap;
    src: local("Montserrat Variable");
  }

  * {
    font-family:
      "Montserrat Variable",
      -apple-system,
      system-ui,
      sans-serif;
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }

  *::selection {
    background-color: var(--sec);
    color: var(--background);
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  ::-webkit-scrollbar {
    display: none;
  }

  /* Hide scrollbar for IE, Edge and Firefox */
  * {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }

  /* Lenis recommended styles */
  html.lenis,
  html.lenis body {
    height: auto;
  }
  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }
  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }
  .lenis.lenis-stopped {
    overflow: hidden;
  }
  .lenis.lenis-smooth iframe {
    pointer-events: none;
  }

  /* Smooth Theme view transition styles (circular paint wipe) */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
  }
  ::view-transition-old(root) {
    z-index: 1;
  }
  ::view-transition-new(root) {
    z-index: 999999;
  }
</style>
