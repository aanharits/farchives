---
import "@fontsource-variable/montserrat";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Hi, my name is Farhan Harits Prakoso and this is my portfolio. Check it out!"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="preconnect" href="https://open.spotify.com" />
    <link rel="dns-prefetch" href="https://open.spotify.com" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Hi, my name is Farhan Harits Prakoso and this is my portfolio. Check it out!"
    />
    <meta property="og:image" content="https://www.farchives.dev/favicon.png" />
    <meta property="og:url" content="https://www.farchives.dev" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Farhan | Portofolio" />

    <title>{title}</title>

    <!-- Set theme early to prevent dark/light flash on reload & setup JS class -->
    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();
      document.documentElement.setAttribute("data-theme", theme);
      document.documentElement.classList.add("js");
    </script>

    <!-- Bundle GSAP and Lenis locally for better performance -->
    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      // Expose globally so other components can access them directly
      (window as any).gsap = gsap;
      (window as any).ScrollTrigger = ScrollTrigger;
      (window as any).Lenis = Lenis;

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: "vertical",
        gestureOrientation: "vertical",
        smoothWheel: true,
        wheelMultiplier: 1,
        smoothTouch: false,
        touchMultiplier: 2,
        infinite: false,
      } as any);

      (window as any).lenis = lenis;

      lenis.on("scroll", ScrollTrigger.update);
      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });
      gsap.ticker.lagSmoothing(0, 0);

      // Refresh ScrollTrigger and Lenis after all assets (fonts, images) are fully loaded
      window.addEventListener("load", () => {
        ScrollTrigger.refresh();
        lenis.resize();
      });
    </script>
  </head>
  <body class="bg-[--background]">
    <slot />
  </body>
</html>

<style is:global>
  /* Ensure fixed nav elements are always visible */
  #hamburger-btn,
  #theme-toggle {
    position: fixed !important;
    will-change: transform;
    transform: translateZ(0);
  }

  :root {
    --background: #131513;
    --sec: #648e46;
    --white: #dfdfdf;
    --white-icon: #f3f3f398;
    --white-icon-tr: #f3f3f310;
    --component-bg: #1a1d1a;
    --nav-active: #ffffff;
  }

  [data-theme="light"] {
    --background: #f0e9d4;
    --sec: #74824a;
    --white: #41431b;
    --white-icon: #41431b98;
    --white-icon-tr: #41431b10;
    --component-bg: #d7d0b6;
    --nav-active: #41431b;
  }

  html,
  body {
    transition:
      background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      color 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Smooth theme transition for all elements */
  *,
  *::before,
  *::after {
    transition:
      background-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      border-color 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      fill 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      stroke 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Re-allow fast transitions for interactive/animated elements */
  button,
  a,
  [class*="transition"],
  [class*="duration"],
  [class*="ease"] {
    transition-duration: revert !important;
    transition-timing-function: revert !important;
  }

  /* Alternating section styling */
  .alt-section {
    background-color: var(--sec) !important;
  }

  /* Apply text color to direct text elements unless they are inside a card (.themed-card) */
  .alt-section h1:not(.themed-card *),
  .alt-section h2:not(.themed-card *),
  .alt-section h3:not(.themed-card *),
  .alt-section h4:not(.themed-card *) {
    color: var(--background) !important;
  }
  .alt-section p:not(.themed-card *),
  .alt-section span:not(.themed-card *),
  .alt-section a:not(.themed-card *) {
    color: var(--background) !important;
  }
  .alt-section border:not(.themed-card *) {
    border-color: color-mix(
      in srgb,
      var(--background) 20%,
      transparent
    ) !important;
  }
  /* Preserve some specific elements in alt-section */
  .alt-section .exp-badge:not(.themed-card *) {
    color: var(--background) !important;
  }
  .alt-section svg:not(.themed-card *) {
    stroke: var(--background) !important;
  }
  .alt-section [class*="text-[var(--sec)]"]:not(.themed-card *) {
    color: var(--background) !important;
  }

  * {
    font-family:
      "Montserrat Variable",
      -apple-system,
      system-ui,
      sans-serif;
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }

  *::selection {
    background-color: var(--sec);
    color: var(--background);
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  ::-webkit-scrollbar {
    display: none;
  }

  /* Hide scrollbar for IE, Edge and Firefox */
  * {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }

  /* Lenis recommended styles */
  html.lenis,
  html.lenis body {
    height: auto;
  }
  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }
  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }
  .lenis.lenis-stopped {
    overflow: hidden;
  }
  .lenis.lenis-smooth iframe {
    pointer-events: none;
  }

</style>

