<section id="contact" class="py-20 md:py-20 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4">
    <!-- Mobile Layout: Stacked -->
    <div class="block md:hidden">
      <div class="relative">
        <!-- Circle - Positioned left -->
        <div
          class="absolute -left-12 sm:-left-16 top-0 w-52 sm:w-64 h-52 sm:h-64 rounded-full bg-[var(--sec)]"
          data-contact-circle
        >
        </div>

        <!-- Content below circle -->
        <div class="relative pt-32 sm:pt-48">
          <!-- Title -->
          <h2
            class="text-5xl sm:text-5xl font-serif italic text-[var(--white)] leading-[0.9] mb-8 sm:mb-8"
            data-contact-title
          >
            Let's<br />Connect
          </h2>

          <!-- Description -->
          <p
            class="text-sm text-[var(--white-icon)] leading-relaxed mb-8"
            data-contact-content
          >
            I'm remote-friendly and always open to new opportunities. Feel free
            to email me at <a
              href="mailto:farhan.harits05@gmail.com"
              class="text-[var(--white)] hover:text-[var(--sec)] transition-colors font-medium"
              >farhan.harits05@gmail.com</a
            >. You can also find me on <a
              href="https://github.com/aanharits"
              target="_blank"
              class="text-[var(--white)] hover:text-[var(--sec)] transition-colors font-medium"
              >GitHub</a
            > and
            <a
              href="https://www.linkedin.com/in/farhan-harits-prakoso/"
              target="_blank"
              class="text-[var(--white)] hover:text-[var(--sec)] transition-colors font-medium"
              >LinkedIn</a
            >, for more details.
          </p>

          <!-- Spotify Section -->
          <div class="mt-8" data-contact-content>
            <p class="text-sm text-[var(--white-icon)] mb-4">
              Let's be <a
                href="https://open.spotify.com/user/312467646"
                target="_blank"
                class="text-[var(--white)] hover:text-[var(--sec)] transition-colors font-medium"
                >Spotify</a
              > moots! Check out what I'm listening to:
            </p>
            <iframe
              data-testid="embed-iframe"
              style="border-radius:12px"
              src="https://open.spotify.com/embed/playlist/5YRcKyMlyTFGZnW8SomGHH?utm_source=generator"
              width="100%"
              height="152"
              allowfullscreen=""
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
            >
            </iframe>
          </div>
        </div>
      </div>
    </div>

    <!-- Desktop Layout: Side by side -->
    <div class="hidden md:block">
      <div class="relative min-h-[450px]">
        <!-- Decorative Circle -->
        <div
          class="absolute left-0 md:left-4 top-0 w-[300px] h-[300px] lg:w-[400px] lg:h-[400px] rounded-full bg-[var(--sec)]"
          data-contact-circle-desktop
        >
        </div>

        <!-- Let's Connect Title -->
        <div
          class="absolute left-8 md:left-12 lg:left-24 bottom-8 z-10"
          data-contact-title-desktop
        >
          <h2
            class="text-6xl lg:text-8xl font-serif italic text-[var(--white)] leading-[0.9]"
          >
            Let's<br />Connect
          </h2>
        </div>

        <!-- Description & Spotify - Right side -->
        <div
          class="absolute right-0 top-1/2 -translate-y-1/2 w-[55%] md:w-[50%] lg:w-[45%]"
          data-contact-content-desktop
        >
          <p
            class="text-base lg:text-lg text-[var(--white-icon)] leading-relaxed mb-6"
          >
            I'm remote-friendly and always open to new opportunities. Feel free
            to email me at <a
              href="mailto:farhan.harits05@gmail.com"
              class="text-[var(--white)] hover:text-[var(--sec)] transition-colors font-medium"
              >farhan.harits05@gmail.com</a
            >. You can also find me on <a
              href="https://github.com/aanharits"
              target="_blank"
              class="text-[var(--white)] hover:text-[var(--sec)] transition-colors font-medium"
              >GitHub</a
            > and
            <a
              href="https://www.linkedin.com/in/farhan-harits-prakoso/"
              target="_blank"
              class="text-[var(--white)] hover:text-[var(--sec)] transition-colors font-medium"
              >LinkedIn</a
            >, for more details.
          </p>

          <!-- Spotify Section -->
          <div class="mt-8">
            <p class="text-md text-[var(--white-icon)] mb-3">
              Let's be <a
                href="https://open.spotify.com/user/hqu6f5db55iw7206tew9b4my4?si=33d2b2ce84fa42f7"
                target="_blank"
                class="text-[var(--white)] hover:text-[var(--sec)] transition-colors font-medium"
                >Spotify</a
              > moots! Check out what I'm listening to:
            </p>
            <iframe
              data-testid="embed-iframe"
              style="border-radius:12px"
              src="https://open.spotify.com/embed/playlist/5YRcKyMlyTFGZnW8SomGHH?utm_source=generator"
              width="100%"
              height="152"
              allowfullscreen=""
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
            >
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // --- Lazy-load Spotify iframes ---
    const spotifyFrames = document.querySelectorAll("iframe.spotify-lazy");
    if (spotifyFrames.length > 0) {
      const lazyObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const iframe = entry.target as HTMLIFrameElement;
              const src = iframe.getAttribute("data-src");
              if (src && !iframe.src) {
                iframe.src = src;
              }
              lazyObserver.unobserve(iframe);
            }
          });
        },
        { rootMargin: "200px" },
      );

      spotifyFrames.forEach((frame) => lazyObserver.observe(frame));
    }

    // --- GSAP Animations ---
    // @ts-ignore
    const gsap = window.gsap;
    // @ts-ignore
    const ScrollTrigger = window.ScrollTrigger;
    if (!gsap || !ScrollTrigger) return;

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const isMobile = window.innerWidth < 768;
    const dur = prefersReduced ? 0.01 : 0.8;

    if (isMobile) {
      // Mobile animations
      gsap.from("[data-contact-circle]", {
        scale: 0,
        opacity: 0,
        duration: dur * 1.2,
        ease: "back.out(1.2)",
        scrollTrigger: {
          trigger: "#contact",
          start: "top 85%",
          toggleActions: "play none none none",
        },
      });

      gsap.from("[data-contact-title]", {
        x: -30,
        opacity: 0,
        duration: dur,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#contact",
          start: "top 75%",
          toggleActions: "play none none none",
        },
      });

      gsap.from("[data-contact-content]", {
        y: 25,
        opacity: 0,
        duration: dur * 0.9,
        stagger: 0.15,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#contact",
          start: "top 70%",
          toggleActions: "play none none none",
        },
      });
    } else {
      // Desktop animations
      gsap.from("[data-contact-circle-desktop]", {
        scale: 0,
        opacity: 0,
        duration: dur * 1.3,
        ease: "back.out(1.2)",
        scrollTrigger: {
          trigger: "#contact",
          start: "top 75%",
          toggleActions: "play none none none",
        },
      });

      gsap.from("[data-contact-title-desktop]", {
        x: -50,
        opacity: 0,
        duration: dur,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#contact",
          start: "top 70%",
          toggleActions: "play none none none",
        },
      });

      gsap.from("[data-contact-content-desktop]", {
        x: 50,
        opacity: 0,
        duration: dur,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#contact",
          start: "top 65%",
          toggleActions: "play none none none",
        },
      });
    }
  });
</script>
