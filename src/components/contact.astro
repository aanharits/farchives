<script>
  // Lazy-load Spotify iframes when they come into view
  const spotifyFrames = document.querySelectorAll("iframe.spotify-lazy");
  if (spotifyFrames.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const iframe = entry.target as HTMLIFrameElement;
            const src = iframe.getAttribute("data-src");
            if (src && !iframe.src) {
              iframe.src = src;
            }
            observer.unobserve(iframe);
          }
        });
      },
      { rootMargin: "200px" },
    );

    spotifyFrames.forEach((frame) => observer.observe(frame));
  }
</script>
