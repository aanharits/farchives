---
import { cats } from "../data/cats";
---

<div
  class="cats-widget-wrapper w-full max-w-sm mx-auto lg:mx-0 lg:ml-auto my-2 lg:my-6"
  data-terminal-widget
>
  <!-- Fun typography header above terminal -->
  <div class="mb-4 px-1">
    <p class="text-xs md:text-sm font-medium italic text-[var(--background)]">
      "Oh, and I'm also a huge cat person. Meet the squad!"
    </p>
  </div>

  <div
    class="cats-terminal flex flex-col rounded-xl overflow-hidden border border-[var(--white-icon-tr)] bg-[#1e1e1e] shadow-2xl relative"
  >
    <!-- Terminal Header (Mac Style) -->
    <div
      class="terminal-header flex items-center px-4 py-3 bg-[#2d2d2d] border-b border-[var(--white-icon-tr)]"
    >
      <div class="flex gap-2">
        <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
        <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
        <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
      </div>
      <div
        class="flex-1 text-center text-[0.7rem] font-mono !text-gray-400 font-semibold tracking-wide"
      >
        ~/farhan's_cats_gallery
      </div>
    </div>

    <!-- Terminal Body (Carousel Slider) -->
    <div class="terminal-body relative group w-full">
      <!-- Prev Button -->
      <button
        class="slider-btn prev-btn absolute left-2 top-1/2 -translate-y-1/2 z-10 w-8 h-8 flex items-center justify-center rounded bg-black/40 hover:bg-black/80 transition-all opacity-0 group-hover:opacity-100 disabled:opacity-0"
        aria-label="Previous cat"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="white"
          style="stroke: white !important;"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg
        >
      </button>

      <!-- Slider Container -->
      <div
        class="cats-slider flex overflow-x-auto snap-x snap-mandatory hide-scrollbar scroll-smooth"
        id="cats-slider"
      >
        {
          cats.map((cat) => (
            <div class="cat-slide w-full shrink-0 snap-center flex flex-col p-4 md:p-6 min-h-[180px] md:min-h-[200px]">
              <div
                class="terminal-prompt font-mono text-xs md:text-sm mb-3 md:mb-4"
                style="color: #4af626 !important;"
              >
                <span class="font-medium" style="color: white !important;">
                  guest@farchives:~$
                </span>{" "}
                ./show_cat.sh --name {cat.name.toLowerCase()}
              </div>

              <div class="cat-ascii-wrapper flex-1 flex items-center justify-center">
                <pre
                  class="cat-ascii font-mono text-sm md:text-base leading-tight text-center"
                  style="color: #4af626 !important;"
                  set:text={cat.ascii}
                ></pre>
              </div>

              <div
                class="terminal-prompt mt-4 font-mono text-[0.65rem] flex items-center gap-2"
                style="color: rgba(74, 246, 38, 0.7) !important;"
              >
                <span class="animate-pulse">_</span>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Next Button -->
      <button
        class="slider-btn next-btn absolute right-2 top-1/2 -translate-y-1/2 z-10 w-8 h-8 flex items-center justify-center rounded bg-black/40 hover:bg-black/80 transition-all opacity-0 group-hover:opacity-100 disabled:opacity-0"
        aria-label="Next cat"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="white"
          style="stroke: white !important;"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
        >
      </button>
    </div>
  </div>
</div>

<style>
  /* Ensure monospace font for ASCII */
  .cat-ascii {
    font-family: "JetBrains Mono", "Courier New", Courier, monospace;
    letter-spacing: 0;
  }

  /* Hide scrollbar for cleaner look */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // @ts-ignore
    const gsap = window.gsap;
    // @ts-ignore
    const ScrollTrigger = window.ScrollTrigger;
    if (!gsap || !ScrollTrigger) return;

    let ctx = gsap.context(() => {
      // 1. Entrance Animation
      gsap.from("[data-terminal-widget]", {
        y: 40,
        opacity: 0,
        scale: 0.95,
        duration: 1,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "[data-terminal-widget]",
          start: "top 85%",
          once: true,
        },
      });

      // 2. Idle animations for all cats
      const asciis = document.querySelectorAll(".cat-ascii");
      asciis.forEach((ascii) => {
        // Subtle breathing (ambient idle)
        gsap.to(ascii, {
          y: -3,
          duration: 1.5,
          yoyo: true,
          repeat: -1,
          ease: "sine.inOut",
          delay: Math.random(), // offset breathing
        });
      });

      // 3. Slider logic for prev/next buttons
      const slider = document.getElementById("cats-slider");
      const prevBtn = document.querySelector(".prev-btn") as HTMLButtonElement;
      const nextBtn = document.querySelector(".next-btn") as HTMLButtonElement;

      if (!slider || !prevBtn || !nextBtn) return;

      const updateButtons = () => {
        const scrollLeft = slider.scrollLeft;
        const maxScroll = slider.scrollWidth - slider.clientWidth;

        if (scrollLeft <= 0) {
          prevBtn.disabled = true;
          prevBtn.style.opacity = "0";
          prevBtn.style.pointerEvents = "none";
        } else {
          prevBtn.disabled = false;
          prevBtn.style.opacity = "";
          prevBtn.style.pointerEvents = "auto";
        }

        if (Math.ceil(scrollLeft) >= maxScroll) {
          nextBtn.disabled = true;
          nextBtn.style.opacity = "0";
          nextBtn.style.pointerEvents = "none";
        } else {
          nextBtn.disabled = false;
          nextBtn.style.opacity = "";
          nextBtn.style.pointerEvents = "auto";
        }
      };

      slider.addEventListener("scroll", updateButtons);
      updateButtons(); // initial state

      prevBtn.addEventListener("click", () => {
        slider.scrollBy({ left: -slider.clientWidth, behavior: "smooth" });
      });

      nextBtn.addEventListener("click", () => {
        slider.scrollBy({ left: slider.clientWidth, behavior: "smooth" });
      });
    });

    document.addEventListener(
      "astro:before-swap",
      () => {
        ctx.revert();
      },
      { once: true },
    );
  });
</script>
