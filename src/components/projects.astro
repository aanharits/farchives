---
import { Image } from "astro:assets";
import collateral from "../../public/collateral.png";
import paperlane from "../../public/paperlane.png";
import sayurhub from "../../public/sayurhub.jpeg";
import emigria from "../../public/emigria.jpeg";
import sehathemat from "../../public/sehathemat.jpeg";

interface Project {
  title: string;
  image: ImageMetadata;
  link: string;
  preview: string;
  description: string;
}

const projects: Project[] = [
  {
    title: "Emigria (Capstone Project)",
    image: emigria as ImageMetadata,
    link: "https://github.com/EMIGRIA",
    preview: "https://www.emigria.my.id/",
    description: "Emigria is a multimodal AI-powered overseas job fraud detection platform developed to address a critical vulnerability faced by Indonesian migrant worker candidates: how to verify job offers quickly before trusting recruitment claims that may be misleading, unsafe, or fraudulent.",
  },
  {
    title: "Social-Collateral (Hackaton Project)",
    image: collateral as ImageMetadata,
    link: "https://github.com/SocialCollateralAI",
    preview: "https://socialcollateral-landingpage.vercel.app/",
    description: "SocialCollateral AI is a specialized Social Graph Engine developed to address a critical paradox in the microfinance industry: how to scale inclusive lending without losing the \"social touch\" that mitigates risk.",
  },
  {
    title: "SehatHemat (On Development)",
    image: sehathemat as ImageMetadata,
    link: "https://github.com/aanharits/SehatHemat",
    preview: "https://github.com/aanharits/SehatHemat",
    description: "An AI-powered weekly meal planner for people starting their fitness journey on any budget. Users input their budget, calorie, and protein targets, and the AI generates a full week of meals (breakfast, lunch, dinner) using a RAG approach with a curated Kaggle nutrition dataset.",
  },
  {
    title: "Sayurhub (Course Project)",
    image: sayurhub as ImageMetadata,
    link: "https://github.com/aanharits/sayurhub",
    preview: "https://sayurhub.vercel.app/",
    description: "An e-commerce web app focused on fresh daily needs vegetables, fruits, and cooking spices. Built to make it easy for people to shop for kitchen essentials online.",
  },
  {
    title: "Paperlane",
    image: paperlane as ImageMetadata,
    link: "https://github.com/aanharits/be_post",
    preview: "https://paperlane.vercel.app/",
    description: "My first project from learning to code, a notes management app where you can create, organize, and manage your notes. I also added authentication to deepen my understanding of user auth flows.",
  },

];
---

<section id="projects" class="py-12 md:py-20 lg:py-28 text-[var(--white)]">
  <div class="max-w-5xl mx-auto px-4">
    
    <!-- Layout like About Section - Title left, Projects right -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
      
      <!-- Title Column -->
      <div class="md:col-span-3" data-proj-title>
        <h2 class="text-2xl md:text-3xl font-medium italic text-[var(--sec)] mb-4">
          Projects
        </h2>
        <a
          target="_blank"
          href="https://github.com/aanharits"
          class="inline-flex items-center gap-2 text-sm text-[var(--white-icon)] hover:text-[var(--sec)] transition-colors group"
        >
          more
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 group-hover:translate-x-1 transition-transform">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Projects Carousel -->
      <div class="md:col-span-9">
        <div
          id="projects-carousel"
          class="projects-carousel flex gap-6 overflow-x-auto scroll-smooth pb-4 cursor-grab active:cursor-grabbing"
        >
          {
            projects.map((project, index) => (
              <div
                class="project-card group block min-w-[280px] flex-[0_0_calc(33.333%-1rem)] lg:flex-[0_0_calc(33.333%-1rem)] md:flex-[0_0_calc(50%-0.75rem)] max-sm:flex-[0_0_85%] snap-start select-none"
                data-proj-card
              >
                <div class="border border-[var(--white-icon-tr)] shadow-md rounded-[14px] overflow-hidden transition-all duration-300 h-full flex flex-col hover:-translate-y-0.5 group-hover:border-[var(--sec)] group-hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)]">
                  <!-- Project Image -->
                  <div class="overflow-hidden aspect-[16/10]">
                    <Image
                      src={project.image}
                      alt={project.title}
                      width={400}
                      format="webp"
                      quality={75}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover transition-transform duration-[600ms] ease-[cubic-bezier(0.4,0,0.2,1)] group-hover:scale-105 pointer-events-none"
                    />
                  </div>

                  <!-- Card Content -->
                  <div class="p-5 pb-5 flex-1 flex flex-col gap-3">
                    <div class="flex items-center justify-between">
                      <span class="text-[0.7rem] font-semibold tracking-widest text-[var(--sec)] opacity-70">
                        {String(index + 1).padStart(2, "0")}
                      </span>
                      <div class="flex items-center gap-2">
                        <a
                          href={project.link}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="proj-btn proj-btn--icon"
                          aria-label="View on GitHub"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                          </svg>
                        </a>
                        {project.preview && project.preview !== project.link && (
                          <a
                            href={project.preview}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="proj-btn proj-btn--icon"
                            aria-label="View live demo"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                              <polyline points="15 3 21 3 21 9"/>
                              <line x1="10" y1="14" x2="21" y2="3"/>
                            </svg>
                          </a>
                        )}
                      </div>
                    </div>
                    <h4 class="text-[1.05rem] font-semibold text-[var(--white)] transition-colors duration-300 group-hover:text-[var(--sec)]">
                      {project.title}
                    </h4>
                    <p class="text-[0.82rem] leading-relaxed text-[var(--white-icon)] flex-1">
                      {project.description}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <!-- Dot Indicators -->
        <div class="flex justify-center gap-2 mt-5" id="carousel-dots">
          {projects.map((_, i) => (
            <button
              class={`carousel-dot h-2 rounded-full border-none bg-[var(--white-icon-tr)] cursor-pointer transition-all duration-300 p-0 hover:bg-[var(--white-icon)] ${i === 0 ? "w-5 !bg-[var(--sec)]" : "w-2"}`}
              data-index={i}
              aria-label={`Go to project ${i + 1}`}
            />
          ))}
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* Only styles that have no Tailwind equivalent */
  .projects-carousel {
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .projects-carousel::-webkit-scrollbar {
    display: none;
  }
  .project-card {
    -webkit-user-drag: none;
  }
  .project-card img {
    pointer-events: none;
  }

  /* Action buttons */
  .proj-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    border: 1px solid var(--white-icon-tr);
    color: var(--white-icon);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    cursor: pointer;
  }
  .proj-btn--icon {
    padding: 5px;
  }
  .proj-btn:hover {
    color: var(--sec);
    border-color: var(--sec);
    background: color-mix(in srgb, var(--sec) 8%, transparent);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // --- GSAP Animations ---
    // @ts-ignore
    const gsap = window.gsap;
    // @ts-ignore
    const ScrollTrigger = window.ScrollTrigger;

    if (gsap && ScrollTrigger) {
      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const isMobile = window.innerWidth < 768;
      const dur = prefersReduced ? 0.01 : 0.6;

      // Title slide from left
      gsap.from("[data-proj-title]", {
        x: isMobile ? -20 : -40,
        opacity: 0,
        duration: dur,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#projects",
          start: isMobile ? "top 85%" : "top 75%",
          toggleActions: "play none none none",
        },
      });

      // Project cards staggered
      gsap.from("[data-proj-card]", {
        y: isMobile ? 25 : 40,
        opacity: 0,
        duration: dur * 1.1,
        stagger: 0.2,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#projects",
          start: isMobile ? "top 80%" : "top 70%",
          toggleActions: "play none none none",
        },
      });
    }

    // --- Carousel Logic ---
    const carousel = document.getElementById("projects-carousel");
    const dots = document.querySelectorAll(".carousel-dot");

    if (carousel && dots.length > 0) {
      // Update active dot on scroll
      carousel.addEventListener("scroll", () => {
        const scrollLeft = carousel.scrollLeft;
        const cardWidth = carousel.querySelector(".project-card")?.clientWidth || 280;
        const gap = 24; // 1.5rem
        const activeIndex = Math.round(scrollLeft / (cardWidth + gap));

        dots.forEach((dot, i) => {
          if (i === activeIndex) {
            dot.classList.add("w-5", "!bg-[var(--sec)]");
            dot.classList.remove("w-2");
          } else {
            dot.classList.remove("w-5", "!bg-[var(--sec)]");
            dot.classList.add("w-2");
          }
        });
      }, { passive: true });

      // Click dot to scroll
      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const index = Number(dot.getAttribute("data-index"));
          const cardWidth = carousel.querySelector(".project-card")?.clientWidth || 280;
          const gap = 24;
          carousel.scrollTo({ left: index * (cardWidth + gap), behavior: "smooth" });
        });
      });

      // Drag to scroll
      let isDown = false;
      let startX: number;
      let scrollLeft: number;

      carousel.addEventListener("mousedown", (e) => {
        isDown = true;
        startX = e.pageX - carousel.offsetLeft;
        scrollLeft = carousel.scrollLeft;
      });

      carousel.addEventListener("mouseleave", () => { isDown = false; });
      carousel.addEventListener("mouseup", () => { isDown = false; });

      carousel.addEventListener("mousemove", (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - carousel.offsetLeft;
        const walk = (x - startX) * 1.5;
        carousel.scrollLeft = scrollLeft - walk;
      });
    }
  });
</script>
