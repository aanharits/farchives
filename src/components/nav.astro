---
interface NavItem {
  label: string;
  href: string;
}

const navItems: NavItem[] = [
  { label: "Home", href: "#home" },
  { label: "About", href: "#about" },
  { label: "Experience", href: "#experience" },
  { label: "Projects", href: "#projects" },
  { label: "Contact", href: "#contact" },
];
---

<!-- Hamburger Toggle Button -->
<button
  id="hamburger-btn"
  class="fixed top-6 right-[88px] z-[120] flex flex-col items-center justify-center gap-[4px] w-[42px] h-[42px] border border-transparent rounded-full bg-[var(--background)] cursor-pointer backdrop-blur-[12px] transition-all duration-300 ease-in-out hover:bg-[var(--component-bg)] hover:border-[#ffffff10] hover:scale-[1.08] hover:shadow-[0_4px_20px_rgba(0,0,0,0.3)] active:scale-95"
  aria-label="Toggle navigation menu"
>
  <span class="w-[18px] h-[1.5px] bg-[var(--white-icon)] transition-all duration-300 origin-center rounded-full pointer-events-none"></span>
  <span class="w-[18px] h-[1.5px] bg-[var(--white-icon)] transition-all duration-300 origin-center rounded-full pointer-events-none"></span>
</button>

<!-- Dropdown Navigation Menu -->
<nav
  id="nav-menu"
  class="fixed top-[80px] right-9 z-[110] w-[200px] border border-[#ffffff10] rounded-[20px] shadow-2xl backdrop-blur-2xl opacity-0 translate-y-[-10px] pointer-events-none transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]"
>
  <ul class="flex flex-col py-3 px-2">
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="nav-link flex items-center justify-between px-4 py-3 text-[0.85rem] font-medium text-[var(--white-icon)] rounded-[14px] transition-all duration-300 hover:text-[var(--white)] hover:bg-[var(--white-icon-tr)] hover:border-[#ffffff10] border border-transparent"
            data-target={item.href.substring(1)}
          >
            {item.label}
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--sec)] opacity-0 transition-opacity duration-300 nav-indicator"></span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  #nav-menu {
    background-color: color-mix(in srgb, var(--component-bg) 85%, transparent);
  }

  nav a.active {
    color: var(--white) !important;
    background-color: var(--white-icon-tr);
    border-color: rgba(255, 255, 255, 0.08);
  }
  nav a.active .nav-indicator {
    opacity: 1;
  }
  
  [data-theme="light"] nav a.active {
    border-color: rgba(0, 0, 0, 0.05);
  }
  [data-theme="light"] #nav-menu {
    border-color: rgba(0, 0, 0, 0.05);
  }
</style>

<script>
  const hamburgerBtn = document.getElementById("hamburger-btn");
  const navMenu = document.getElementById("nav-menu");
  const spans = hamburgerBtn?.querySelectorAll("span");
  const navLinks = document.querySelectorAll(".nav-link");
  
  let isOpen = false;

  function toggleMenu() {
    isOpen = !isOpen;
    if (isOpen) {
      navMenu?.classList.remove("opacity-0", "translate-y-[-10px]", "pointer-events-none");
      navMenu?.classList.add("opacity-100", "translate-y-0", "pointer-events-auto");
      
      if (spans && spans.length >= 2) {
        spans[0].style.transform = "translateY(2.75px) rotate(45deg)";
        spans[1].style.transform = "translateY(-2.75px) rotate(-45deg)";
      }
    } else {
      navMenu?.classList.add("opacity-0", "translate-y-[-10px]", "pointer-events-none");
      navMenu?.classList.remove("opacity-100", "translate-y-0", "pointer-events-auto");
      
      if (spans && spans.length >= 2) {
        spans[0].style.transform = "none";
        spans[1].style.transform = "none";
      }
    }
  }

  hamburgerBtn?.addEventListener("click", toggleMenu);

  document.addEventListener("click", (e) => {
    if (isOpen && navMenu && hamburgerBtn && !navMenu.contains(e.target as Node) && !hamburgerBtn.contains(e.target as Node)) {
      toggleMenu();
    }
  });

  navLinks.forEach(link => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const targetId = link.getAttribute("href")?.substring(1) || "";
      const targetElement = document.getElementById(targetId);
      if (targetElement) {
        targetElement.scrollIntoView({ behavior: "smooth" });
        toggleMenu(); // Close menu
      }
    });
  });

  // Scroll styling match theme toggle
  window.addEventListener("scroll", () => {
    if (window.scrollY > 0) {
      hamburgerBtn?.classList.add("!bg-[var(--component-bg)]", "!border-[#ffffff10]");
    } else {
      hamburgerBtn?.classList.remove("!bg-[var(--component-bg)]", "!border-[#ffffff10]");
    }
  }, { passive: true });

  // Intersection Observer for Active Links
  document.addEventListener("DOMContentLoaded", () => {
    // Select specific section targets based on nav links
    const targetSelectors = Array.from(navLinks).map(link => `#${link.getAttribute("data-target")}`).filter(Boolean).join(", ");
    const sections = document.querySelectorAll(targetSelectors);
    
    // Using a reliable threshold and looking at intersecting blocks
    const observerOptions = { 
      root: null,
      threshold: [0.1, 0.4, 0.6, 0.8], 
      rootMargin: "-15% 0px -15% 0px" 
    };

    let activeSectionId = "";
    let maxIntersectionRatio = 0;

    const observerCallback = (entries: IntersectionObserverEntry[]) => {
      let changed = false;
      
      entries.forEach((entry) => {
        if (entry.isIntersecting && entry.intersectionRatio > maxIntersectionRatio) {
          activeSectionId = entry.target.getAttribute("id") || "";
          maxIntersectionRatio = entry.intersectionRatio;
          changed = true;
        } else if (!entry.isIntersecting && entry.target.getAttribute("id") === activeSectionId) {
          maxIntersectionRatio = 0; // Reset if current active section leaves
        }
      });

      if (changed && activeSectionId) {
        navLinks.forEach((link) => link.classList.remove("active"));
        const activeLink = document.querySelector(`.nav-link[data-target="${activeSectionId}"]`);
        if (activeLink) {
          activeLink.classList.add("active");
        }
      }
    };

    const observer = new IntersectionObserver(observerCallback, observerOptions);
    sections.forEach((section) => observer.observe(section));
  });
</script>
