---
import LogoWall from "./logoWall.astro";
import CatsGallery from "./catsGallery.astro";

const para1Text =
  "Hi! I'm Farhan Harits Prakoso, an active IT undergraduate, currently in my 6th semester. I'm working towards a career in web development, whether that's fullstack, backend, or frontend, I'm still figuring out where I fit best. What I do know is that I care about building things that actually work well and feel good to use.";

const para2Text =
  "Right now I'm leveling up on both backend and frontend, exploring how systems are built under the hood while keeping an eye on the interface side. I like staying in the loop: trying out new libraries, poking around AI tools, or just hunting for design inspiration. When I'm not coding, I'm usually down a rabbit hole on YouTube, listening to music, or just vibing. Music basically never stops playing while I work, it's the one constant in my setup.";
---

<!-- About wrapper: tall enough to give scroll room for the word-reveal pin -->
<div id="about-pin-container" class="about-pin-container">
  <!-- The sticky card that stays in view while words reveal -->
  <div
    id="about"
    class="about-sticky-card alt-section w-full min-h-screen flex flex-col justify-start lg:justify-center origin-top px-6 md:px-16 lg:px-20 pt-24 lg:pt-[6vh] pb-16 lg:pb-[4vh] overflow-visible lg:overflow-hidden"
  >
    <div class="w-full">
      <!-- Header row: label left -->
      <div class="about-header" data-about-title>
        <h2 class="text-2xl md:text-3xl font-medium italic about-label">
          About me
        </h2>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-4 w-full mt-2 md:mt-4"
      >
        <!-- 1. Word-reveal paragraphs -->
        <div class="md:col-span-7 xl:col-span-8 order-1">
          <div class="about-body" data-about-body>
            <p id="about-para-1" class="about-para">
              {
                para1Text.split(" ").map((word, i, arr) => (
                  <>
                    <span class="word">{word}</span>
                    {i < arr.length - 1 && " "}
                  </>
                ))
              }
            </p>
            <p id="about-para-2" class="about-para">
              {
                para2Text.split(" ").map((word, i, arr) => (
                  <>
                    <span class="word">{word}</span>
                    {i < arr.length - 1 && " "}
                  </>
                ))
              }
            </p>
          </div>
        </div>

        <!-- 2. Favourite Technologies (Mobile: order-2, Desktop: order-3, full width) -->
        <div
          class="about-tech mt-8 md:mt-4 md:col-span-12 order-2 md:order-3"
          data-tech-section
        >
          <p class="tech-label">Favourite technologies</p>
          <LogoWall />
        </div>

        <!-- 3. Cats Gallery (Mobile: order-3, Desktop: order-2, side column, vertically centered) -->
        <div
          class="cats-widget-container md:col-span-5 xl:col-span-4 mt-4 md:mt-0 order-3 md:order-2 md:self-center"
        >
          <CatsGallery />
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ─── Pin container: height set dynamically by JS ─── */
  .about-pin-container {
    position: relative;
    /* JS will override this with the exact height needed */
    height: 300vh;
  }

  /* ─── Sticky card inside ─── */
  .about-sticky-card {
    position: sticky;
    top: 0;
  }

  /* ─── Header ─── */
  .about-header {
    margin-bottom: 2.5rem;
  }

  .about-label {
    /* inherits alt-section color → --background */
    letter-spacing: 0.04em;
  }

  /* ─── Paragraphs ─── */
  .about-body {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .about-para {
    font-size: clamp(0.95rem, 2vw, 1.45rem);
    font-weight: 500;
    line-height: 1.6;
    letter-spacing: -0.005em;
  }

  /* word spans injected by JS */
  .about-para :global(.word) {
    display: inline;
    /* dim state — on alt-section (green bg) text color is --background */
    opacity: 0.2;
    transition: none; /* driven by GSAP scrub */
    will-change: opacity;
  }

  /* ─── Tech section ─── */
  .about-tech {
    margin-top: 3rem;
  }

  .tech-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  /* ─── Mobile adjustments ─── */
  @media (max-width: 768px) {
    .about-pin-container {
      /* JS computes this too — no fixed override needed */
    }

    .about-para {
      font-size: clamp(0.875rem, 4vw, 1.1rem);
    }

    .about-header {
      margin-bottom: 1.5rem;
    }

    .about-body {
      gap: 1.5rem;
    }

    .about-tech {
      margin-top: 2rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    const isMobile = window.innerWidth < 768;
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    // Title animation
    gsap.from("[data-about-title]", {
      x: isMobile ? -30 : -60,
      opacity: 0,
      filter: "blur(6px)",
      duration: 1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#about-pin-container",
        start: "top 90%",
        toggleActions: "play none none none",
      },
    });

    if (prefersReduced) {
      // skip reveal animation for accessibility
      gsap.set(".about-para .word", { opacity: 1 });
      gsap.set("[data-tech-section]", { opacity: 1 });
      return;
    }

    // Get pre-rendered word spans
    const allWords = Array.from(
      document.querySelectorAll<HTMLElement>(".about-para .word"),
    );

    // set initial dim state
    gsap.set(allWords, { opacity: 0.18 });

    // calculate heights for scroll reveal budget
    const vh = window.innerHeight;
    const wordCount = allWords.length;
    const scrollPerWord = isMobile ? 7 : 6;
    const scrollBudget = wordCount * scrollPerWord;
    const containerHeight = scrollBudget + vh;

    const container = document.getElementById("about-pin-container")!;
    container.style.height = `${containerHeight}px`;

    // word reveal timeline
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#about-pin-container",
        start: "top top",
        end: `+=${scrollBudget}`,
        scrub: true,
        invalidateOnRefresh: true,
        onRefresh: (self) => {
          // recalculate on resize
          const newVh = window.innerHeight;
          const newBudget = allWords.length * scrollPerWord;
          container.style.height = `${newBudget + newVh}px`;
          (self as any).end = self.start + newBudget;
        },
      },
    });

    // snap opacity for each word staggered
    tl.to(allWords, {
      opacity: 1,
      duration: 0,
      ease: "none",
      stagger: {
        each: 1,
        from: "start",
      },
    });

    // refresh trigger once layout settles
    requestAnimationFrame(() => ScrollTrigger.refresh());
  });
</script>
