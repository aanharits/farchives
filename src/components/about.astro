---

<section id="about" class="py-12 md:py-20 lg:py-28 text-[var(--white)]">
  <div class="max-w-5xl mx-auto px-4">
    <!-- About Content - 3 Column Layout -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
      <!-- Title Column -->
      <div class="md:col-span-3" data-about-title>
        <h2 class="text-2xl md:text-3xl font-medium italic text-[var(--sec)]">
          About me
        </h2>
      </div>

      <!-- First Text Column -->
      <div class="md:col-span-4" data-about-text>
        <p
          class="text-[var(--white-icon)] leading-relaxed text-sm md:text-base"
        >
          Hi! I'm Farhan Harits Prakoso, <span class="text-[var(--white)]">
            an active IT undergraduate, currently in my 6th semester</span
          >. I'm working towards a career in web development - whether that's
          fullstack, backend, or frontend, I'm still figuring out where I fit
          best. What I do know is that I care about building things that actually
          work well and feel good to use.
        </p>
      </div>

      <!-- Second Text Column -->
      <div class="md:col-span-5" data-about-text>
        <p
          class="text-[var(--white-icon)] leading-relaxed text-sm md:text-base"
        >
          Right now I'm leveling up on both backend and frontend - exploring
          how systems are built under the hood while keeping an eye on the
          interface side. I like staying in the loop: trying out new libraries,
          poking around AI tools, or just hunting for design inspiration on
          Dribbble and random corners of the internet. When I'm not coding, I'm
          usually down a rabbit hole on YouTube, listening to music, or just
          vibing. <span class="text-[var(--white)]">Music</span> basically never
          stops playing while I work - it's the one constant in my setup.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // @ts-ignore
    const gsap = window.gsap;
    // @ts-ignore
    const ScrollTrigger = window.ScrollTrigger;
    if (!gsap || !ScrollTrigger) return;

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const isMobile = window.innerWidth < 768;
    const dur = prefersReduced ? 0.01 : 0.7;

    // Title slide from left
    gsap.from("[data-about-title]", {
      x: isMobile ? -20 : -40,
      opacity: 0,
      duration: dur,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#about",
        start: isMobile ? "top 85%" : "top 75%",
        toggleActions: "play none none none",
      },
    });

    // Text columns staggered fade up
    gsap.from("[data-about-text]", {
      y: isMobile ? 20 : 35,
      opacity: 0,
      duration: dur,
      stagger: 0.15,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#about",
        start: isMobile ? "top 80%" : "top 70%",
        toggleActions: "play none none none",
      },
    });
  });
</script>
