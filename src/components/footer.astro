<footer
  class="w-full py-3 bg-[--background] relative z-10"
  data-footer
>
  <div class="max-w-5xl mx-auto px-9 sm:px-28 lg:px-20 text-center">
    <p class="text-xs md:text-sm text-[var(--white-icon)] tracking-wider opacity-70">
      built by <a href="https://github.com/aanharits" class="text-[var(--white)] hover:text-[var(--sec)] transition-colors font-medium">aanharits</a>.
    </p>
  </div>
</footer>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // @ts-ignore
    const gsap = window.gsap;
    // @ts-ignore
    const ScrollTrigger = window.ScrollTrigger;
    if (!gsap || !ScrollTrigger) return;

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    gsap.from("[data-footer]", {
      opacity: 0,
      y: 10,
      duration: prefersReduced ? 0.01 : 0.5,
      ease: "power2.out",
      scrollTrigger: {
        trigger: "[data-footer]",
        start: "top 95%",
        toggleActions: "play none none none",
      },
    });
  });
</script>
