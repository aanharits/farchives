<!-- Floating Theme Toggle Button (top-right corner) -->
<button
  id="theme-toggle"
  class="fixed top-6 right-9 z-[99999] flex items-center justify-center w-[42px] h-[42px] border border-transparent rounded-full bg-[var(--background)] text-[var(--white-icon)] cursor-pointer backdrop-blur-[12px] transition-all duration-300 ease-in-out hover:text-[var(--white)] hover:bg-[var(--component-bg)] hover:border-[#ffffff10] hover:scale-[1.08] hover:shadow-[0_4px_20px_rgba(0,0,0,0.3)] active:scale-95"
  aria-label="Toggle dark/light mode"
>
  <!-- Sun icon (visible in dark mode) -->
  <svg
    id="sun-icon"
    class="transition-transform duration-300 ease-in-out"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    width="22"
    height="22"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>
  <!-- Moon icon (visible in light mode) -->
  <svg
    id="moon-icon"
    class="transition-transform duration-300 ease-in-out hidden"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    width="22"
    height="22"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  const themeToggle = document.getElementById("theme-toggle");
  const sunIcon = document.getElementById("sun-icon");
  const moonIcon = document.getElementById("moon-icon");
  const root = document.documentElement;

  function setTheme(theme: string) {
    root.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);

    if (theme === "light") {
      sunIcon!.classList.add("hidden");
      moonIcon!.classList.remove("hidden");
    } else {
      sunIcon!.classList.remove("hidden");
      moonIcon!.classList.add("hidden");
    }
  }

  // Initialize from saved preference
  const savedTheme = localStorage.getItem("theme") || "dark";
  setTheme(savedTheme);

  themeToggle?.addEventListener("click", (e) => {
    const current = root.getAttribute("data-theme") || "dark";
    const nextTheme = current === "dark" ? "light" : "dark";

    // @ts-ignore
    if (!document.startViewTransition) {
      setTheme(nextTheme);
      return;
    }

    // Get click position or default to center
    const x = e.clientX ?? window.innerWidth / 2;
    const y = e.clientY ?? window.innerHeight / 2;

    // Distance to furthest corner
    const endRadius = Math.hypot(
      Math.max(x, window.innerWidth - x),
      Math.max(y, window.innerHeight - y),
    );

    // @ts-ignore
    const transition = document.startViewTransition(() => {
      setTheme(nextTheme);
    });

    transition.ready.then(() => {
      const clipPath = [
        `circle(0px at ${x}px ${y}px)`,
        `circle(${endRadius}px at ${x}px ${y}px)`,
      ];

      document.documentElement.animate(
        {
          clipPath: clipPath,
        },
        {
          duration: 900, // 900ms for an ultra-smooth cinematic transition
          easing: "cubic-bezier(0.22, 1, 0.36, 1)", // Ease-out-quint — silky smooth
          pseudoElement: "::view-transition-new(root)",
        },
      );
    });
  });

  // Match nav scroll style
  window.addEventListener(
    "scroll",
    () => {
      if (window.scrollY > 0) {
        themeToggle?.classList.add(
          "!bg-[var(--component-bg)]",
          "!border-[#ffffff10]",
        );
      } else {
        themeToggle?.classList.remove(
          "!bg-[var(--component-bg)]",
          "!border-[#ffffff10]",
        );
      }
    },
    { passive: true },
  );
</script>
