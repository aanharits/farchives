---
interface Experience {
  role: string;
  company: string;
  period: string;
  location: string;
  type: "Remote" | "Onsite" | "Hybrid";
  description: string;
}

const experiences: Experience[] = [
  {
    role: "Full-Stack Developer",
    company: "Coding Camp DBS Foundation",
    period: "Feb 2026 — Jul 2026",
    location: "Indonesia",
    type: "Remote",
    description:
      "Completed an intensive full-stack web development & applied AI/ML program. Built Emigria, a fraud-detection capstone platform. handling the UI, backend, and integrating the team's ML model into a pipeline backed by a Neon (PostgreSQL) database.",
  },
  {
    role: "Top 15 Finalist",
    company: "Amartha x GDG Jakarta Hackathon",
    period: "Nov 2025",
    location: "Jakarta, ID",
    type: "Onsite",
    description:
      "Contributed as Graph Visualization Specialist on a 5-person team that built SocialCollateral AI is a social graph engine for inclusive microfinance lending. Reached Top 15 among 140+ competing teams.",
  },
  {
    role: "Member",
    company: "GDGOC Universitas Gunadarma",
    period: "Nov 2023 — Present",
    location: "Depok, ID",
    type: "Hybrid",
    description:
      "Active member of the Google Developer Groups on Campus chapter at Universitas Gunadarma. Participating in tech events, study jams, and collaborative sessions around Google technologies and open-source.",
  },
];
---

<section
  id="experience"
  class="py-12 md:py-20 lg:py-28 text-[var(--white)] w-full"
>
  <div class="w-full">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
      <!-- Title Column -->
      <div class="md:col-span-3" data-exp-title>
        <h2 class="text-2xl md:text-3xl font-medium italic text-[var(--sec)]">
          Experience
        </h2>
      </div>

      <!-- Experience List -->
      <div class="md:col-span-9">
        <div class="flex flex-col">
          {
            experiences.map((exp, index) => (
              <div
                class={`group py-7 border-b border-[var(--white-icon-tr)] transition-colors duration-300 ${index === 0 ? "pt-0" : ""} ${index === experiences.length - 1 ? "border-b-0" : ""}`}
                data-exp-item
              >
                <div class="flex flex-col gap-3">
                  <div class="flex justify-between items-start gap-4 max-sm:flex-col max-sm:gap-1.5">
                    <div class="flex flex-col gap-1">
                      <h3 class="text-base font-semibold text-[var(--white)] transition duration-300">
                        {exp.role}
                      </h3>
                      <span class="text-[0.82rem] text-[var(--sec)] font-medium block">
                        {exp.company}
                      </span>
                    </div>
                    <div class="flex flex-col items-end gap-1.5 shrink-0 max-sm:items-start">
                      <span class="text-xs font-medium text-[var(--white-icon)] tracking-wide whitespace-nowrap">
                        {exp.period}
                      </span>
                      <span
                        class={`exp-badge exp-badge--${exp.type.toLowerCase()}`}
                      >
                        <span class="exp-badge__dot" />
                        {exp.location} &middot; {exp.type}
                      </span>
                    </div>
                  </div>
                  <p class="text-[0.82rem] leading-relaxed text-[var(--white-icon)]">
                    {exp.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* ── Badge base ── */
  .exp-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  .exp-badge__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Dark mode (default) ── */
  .exp-badge--remote {
    color: rgba(147, 197, 253, 0.75);
  }
  .exp-badge--remote .exp-badge__dot {
    background: rgb(96, 165, 250);
    box-shadow: 0 0 5px rgba(96, 165, 250, 0.55);
  }

  .exp-badge--onsite {
    color: rgba(252, 211, 77, 0.75);
  }
  .exp-badge--onsite .exp-badge__dot {
    background: rgb(251, 191, 36);
    box-shadow: 0 0 5px rgba(251, 191, 36, 0.55);
  }

  .exp-badge--hybrid {
    color: rgba(196, 181, 253, 0.75);
  }
  .exp-badge--hybrid .exp-badge__dot {
    background: rgb(167, 139, 250);
    box-shadow: 0 0 5px rgba(167, 139, 250, 0.55);
  }

  /* ── Light mode ── darker for contrast on cream #f0e9d4 */
  [data-theme="light"] .exp-badge--remote {
    color: #1e3a8a;
  }
  [data-theme="light"] .exp-badge--remote .exp-badge__dot {
    background: #1d4ed8;
    box-shadow: none;
  }

  [data-theme="light"] .exp-badge--onsite {
    color: #78350f;
  }
  [data-theme="light"] .exp-badge--onsite .exp-badge__dot {
    background: #b45309;
    box-shadow: none;
  }

  [data-theme="light"] .exp-badge--hybrid {
    color: #4c1d95;
  }
  [data-theme="light"] .exp-badge--hybrid .exp-badge__dot {
    background: #6d28d9;
    box-shadow: none;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const isMobile = window.innerWidth < 768;
    const dur = prefersReduced ? 0.01 : 0.6;

    // Smooth entrance animations
    gsap.from("[data-exp-title]", {
      x: isMobile ? -30 : -80,
      opacity: 0,
      filter: "blur(8px)",
      duration: 1.2,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#experience",
        start: "top 85%",
        toggleActions: "play none none none",
      },
    });

    gsap.from("[data-exp-item]", {
      y: isMobile ? 30 : 60,
      opacity: 0,
      filter: "blur(8px)",
      stagger: 0.15,
      duration: 1.2,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#experience",
        start: "top 75%",
        toggleActions: "play none none none",
      },
    });
  });
</script>
