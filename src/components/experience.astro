---
interface Experience {
  role: string;
  company: string;
  period: string;
  description: string;
}

const experiences: Experience[] = [
  {
    role: "Member",
    company: "GDGOC Universitas Gunadarma",
    period: "November 2023 — Present",
    description:
      "Participating in GDGOC Universitas Gunadarma events, contributing to open-source projects, and learning new technologies.",
  },
  {
    role: "Top 15 Finalist",
    company: "Amartha x GDG Jakarta Hackaton",
    period: "November 2025",
    description:
      "Achieved a Top 15 finalist position among 140+ diverse teams, including university faculty, industry professionals, and entrepreneurs.",
  },
  {
    role: "Full-stack Developer",
    company: "Coding Camp DBS Foundation",
    period: "February 2026 - Present",
    description:
      "Developing a web application for the DBS Foundation, including user authentication, data management, and reporting features.",
  },
];
---

<section id="experience" class="py-12 md:py-20 lg:py-28 text-[var(--white)]">
  <div class="max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
      <!-- Title Column -->
      <div class="md:col-span-3" data-exp-title>
        <h2 class="text-2xl md:text-3xl font-medium italic text-[var(--sec)]">
          Experience
        </h2>
      </div>

      <!-- Experience List -->
      <div class="md:col-span-9">
        <div class="flex flex-col">
          {
            experiences.map((exp, index) => (
              <div
                class={`group py-7 border-b border-[var(--white-icon-tr)] transition-colors duration-300 ${index === 0 ? "pt-0" : ""} ${index === experiences.length - 1 ? "border-b-0" : ""}`}
                data-exp-item
              >
                <div class="flex flex-col gap-2">
                  <div class="flex justify-between items-start gap-4 max-sm:flex-col-reverse max-sm:gap-1">
                    <div>
                      <h3 class="text-base font-semibold text-[var(--white)] transition duration-300">
                        {exp.role}
                      </h3>
                      <span class="text-[0.82rem] text-[var(--sec)] font-medium mt-0.5 block">
                        {exp.company}
                      </span>
                    </div>
                    <span class="text-xs font-medium text-[var(--white-icon)] tracking-wide whitespace-nowrap pt-0.5 shrink-0">
                      {exp.period}
                    </span>
                  </div>
                  <p class="text-[0.82rem] leading-relaxed text-[var(--white-icon)]">
                    {exp.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // @ts-ignore
    const gsap = window.gsap;
    // @ts-ignore
    const ScrollTrigger = window.ScrollTrigger;
    if (!gsap || !ScrollTrigger) return;

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const isMobile = window.innerWidth < 768;
    const dur = prefersReduced ? 0.01 : 0.6;

    // Title slide from left
    gsap.from("[data-exp-title]", {
      x: isMobile ? -20 : -40,
      opacity: 0,
      duration: dur,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#experience",
        start: isMobile ? "top 85%" : "top 75%",
        toggleActions: "play none none none",
      },
    });

    // Experience items staggered
    gsap.from("[data-exp-item]", {
      y: isMobile ? 20 : 30,
      opacity: 0,
      duration: dur,
      stagger: 0.15,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#experience",
        start: isMobile ? "top 80%" : "top 70%",
        toggleActions: "play none none none",
      },
    });
  });
</script>
